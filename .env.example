# ── Database ──────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://iterallm:secret@localhost:5432/iterallm

# ── Redis ─────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Kafka ─────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_FEEDBACK_TOPIC=feedback-events
KAFKA_CHAT_EVENTS_TOPIC=chat-events

# ── LLM Provider ──────────────────────────────────
LLM_PROVIDER=openai             # openai | anthropic | xai
LLM_API_KEY=sk-your-key-here    # replace with real key
DEFAULT_MODEL=gpt-4o-mini

# ── App Config ────────────────────────────────────
APP_ENV=development             # development | staging | production
APP_PORT=8000
LOG_LEVEL=INFO
MAX_HISTORY_TURNS=20
SESSION_TTL_SECONDS=3600

# ── Observability ─────────────────────────────────
ENABLE_METRICS=true
METRICS_PORT=9090
